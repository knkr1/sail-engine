{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Configure",
            "type": "shell",
            "command": "cmake -B build"
        },
        {
            "label": "Build",
            "type": "shell",
            "command": "cmake --build build",
            "dependsOn": "Configure"
        },
        {
            "label": "Run",
            "type": "shell",
            "command": "cd build; ./program.exe",
            "dependsOn": "Build",
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}